APP_ENV=local
APP_NAME=kordocqa
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://kordocqa:kordocqa@localhost:5432/kordocqa
REDIS_URL=redis://localhost:6379/0

ADMIN_TOKEN=change-me
PROVIDER_NAME=openai
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4.1-mini
EMBEDDING_DIMENSION=1536
MAX_UPLOAD_SIZE_BYTES=10485760
CHUNK_SIZE_CHARS=700
CHUNK_OVERLAP_CHARS=80
RETRIEVAL_TRIGRAM_THRESHOLD=0.2
EMBEDDING_INDEX_BATCH_SIZE=32
EMBEDDING_AUTO_INDEX_MAX_CHUNKS=500
QUERY_TOP_K=5
QUERY_LEXICAL_K=20
QUERY_SEMANTIC_K=20
QUERY_PROMPT_VERSION=v1
EVAL_DEFAULT_DATASET_PATH=app/evals/datasets/ko_sample_eval.jsonl
EVAL_REPORTS_DIR=app/evals/reports
EVAL_CACHE_PREFIX=evals
EVAL_CACHE_TTL_SECONDS=300

ENABLE_TRACING=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
